rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && (
      exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
    ); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 1. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'id', 'email', 'displayName', 'availableBalance', 'role', 'status']) &&
             data.keys().size() >= 7 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.id is string && data.id.size() <= 64 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.availableBalance is number &&
             data.role in ['user', 'admin'] &&
             data.status in ['active', 'suspended'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'amountTo', 'timestamp', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.type in ['convert', 'mining', 'swap', 'transfer', 'deposit', 'withdrawal', 'trade_profit', 'trade_loss'] &&
             data.amountTo is number &&
             data.timestamp is string &&
             data.status in ['approved', 'pending', 'failed', 'rejected'] &&
             (data.keys().hasAny(['assetFrom']) ? data.assetFrom is string && data.assetFrom.size() <= 20 : true) &&
             (data.keys().hasAny(['assetTo']) ? data.assetTo is string && data.assetTo.size() <= 20 : true);
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['id', 'userId', 'asset', 'direction', 'duration', 'amount', 'leverage', 'priceAtEntry', 'returnRate', 'timestamp', 'endTime', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.asset is string && data.asset.size() <= 20 &&
             data.direction in ['up', 'down'] &&
             data.duration is number &&
             data.amount is number &&
             data.leverage is number && data.leverage >= 1 && data.leverage <= 100 &&
             data.priceAtEntry is number &&
             data.returnRate is number &&
             data.timestamp is string &&
             data.endTime is string &&
             data.status in ['pending', 'won', 'lost'] &&
             (data.keys().hasAny(['stopLoss']) ? data.stopLoss is number : true) &&
             (data.keys().hasAny(['takeProfit']) ? data.takeProfit is number : true);
    }

    function isValidKYC(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'documentUrl', 'status', 'submittedAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.type in ['passport', 'id_card', 'driver_license'] &&
             data.documentUrl is string && data.documentUrl.size() <= 1024 &&
             data.status == 'pending' &&
             data.submittedAt is string;
    }

    function isValidAlert(data) {
      return data.keys().hasAll(['id', 'userId', 'asset', 'threshold', 'condition', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.asset is string && data.asset.size() <= 20 &&
             data.threshold is number &&
             data.condition in ['above', 'below'] &&
             data.status in ['active', 'triggered'] &&
             data.createdAt is string;
    }

    // 2. Collection Rules

    match /users/{userId} {
      allow read: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user' && isValidId(userId);
      allow update: if isValidId(userId) && (
                      (isOwner(userId) && isValidUser(incoming()) && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'withdrawalLimitDaily', 'withdrawalLimitMonthly', 'twoFactorThreshold', 'twoFactorEnabled'])) ||
                      (isAdmin() && isValidUser(incoming()) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'kycVerified', 'availableBalance', 'role']))
                    );
    }

    match /transactions/{transactionId} {
      allow get: if (isOwner(existing().userId) || isAdmin()) && isValidId(transactionId);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isOwner(incoming().userId) && isValidTransaction(incoming()) && incoming().status == 'pending' && isValidId(transactionId);
      allow update: if isValidId(transactionId) && isAdmin() && isValidTransaction(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'amountTo', 'updatedAt']);
      allow delete: if isValidId(transactionId) && isAdmin();
    }

    match /trades/{tradeId} {
      allow get: if (isOwner(existing().userId) || isAdmin()) && isValidId(tradeId);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isOwner(incoming().userId) && isValidTrade(incoming()) && incoming().status == 'pending' && isValidId(tradeId);
      allow update: if isValidId(tradeId) && (
                      (isOwner(existing().userId) && isValidTrade(incoming()) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['stopLoss', 'takeProfit'])) ||
                      (isAdmin() && isValidTrade(incoming()) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'priceAtExit', 'profit', 'endTime']))
                    );
    }

    match /kycDocuments/{docId} {
      allow get: if (isOwner(existing().userId) || isAdmin()) && isValidId(docId);
      allow list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(incoming().userId) && isValidKYC(incoming()) && isValidId(docId);
      allow update: if isValidId(docId) && isAdmin() &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'reviewedAt', 'rejectionReason']);
    }

    match /alerts/{alertId} {
      allow get: if isOwner(existing().userId) && isValidId(alertId);
      allow list: if isOwner(resource.data.userId);
      allow create: if isOwner(incoming().userId) && isValidAlert(incoming()) && isValidId(alertId);
      allow update: if isValidId(alertId) && isOwner(existing().userId) && isValidAlert(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['threshold', 'condition', 'status']);
      allow delete: if isValidId(alertId) && isOwner(existing().userId);
    }
    
    // Explicitly secure auditLogs
    match /auditLogs/{logId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn(); // Allow logging of actions
    }
  }
}


